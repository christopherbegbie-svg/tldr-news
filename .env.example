# ── Anthropic (Claude) ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── X / Twitter API v2 ─────────────────────────────────
# Get these from developer.twitter.com → your app → Keys and Tokens
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_secret
X_BEARER_TOKEN=your_x_bearer_token

# ── Meta / Instagram Graph API ─────────────────────────
# Get from developers.facebook.com → your Business App
META_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# ── NewsAPI.org (optional supplement) ──────────────────
# Free tier at newsapi.org → 100 requests/day
NEWSAPI_KEY=your_newsapi_key

# ── Scheduling ─────────────────────────────────────────
# Comma-separated 24h times (UTC)
POST_TIMES=08:00,12:00,17:00,21:00

# ── Behaviour ──────────────────────────────────────────
# Set to true to print output without actually posting
DRY_RUN=false
